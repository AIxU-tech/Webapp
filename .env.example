# Production database (used when running outside Docker)
DATABASE_URL=postgresql://user:password@host:port/dbname

# Email configuration
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=your_email_password
ADMIN_EMAIL=admin@example.com

# Optional: Anthropic API key for AI features
ANTHROPIC_API_KEY=sk-ant-api03-xxx

# Docker development environment (used by docker-compose)
DEV_DATABASE_URL=postgresql://aixu:aixu_dev_password@db:5432/aixu
DEV_SECRET_KEY=docker-dev-secret-key-change-in-production
