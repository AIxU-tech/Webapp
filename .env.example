# Production database (used when running outside Docker)
DATABASE_URL=postgresql://user:password@host:port/dbname

# Email configuration
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=your_email_password
ADMIN_EMAIL=admin@example.com

# Optional: Anthropic API key for AI features
ANTHROPIC_API_KEY=sk-ant-api03-xxx

# Google Cloud Storage (for file attachments)
# See GCS_SETUP.md for setup instructions
GCS_BUCKET_NAME=aixu-media-your-project-id
# GCS_PROJECT_ID is your Google Cloud project ID. Required when using ADC (Docker / gcloud auth application-default login).
GCS_PROJECT_ID=your-gcp-project-id

# GCS Credentials - use ONE of these methods:
#
# 1. For Render/Production: Base64-encoded service account JSON
#    Generate with: cat your-service-account.json | base64
# GCS_CREDENTIALS_JSON=ewogICJ0eXBlIjogInNlcnZpY2VfYWNjb3VudCIsLi4u
#
# 2. For local development and Docker: service account key file (required for signed URLs).
#    Uploads need a private key; user ADC (gcloud auth application-default login) cannot sign.
#    Create key in GCP Console (IAM > Service Accounts > flask-storage-manager > Keys) or via Terraform.
# GCS_CREDENTIALS_PATH=./flask-sa-key.json
#
# 3. Docker: place flask-sa-key.json in Webapp/ and docker-compose will mount it.

# Docker development environment (used by docker-compose)
DEV_DATABASE_URL=postgresql://aixu:aixu_dev_password@db:5432/aixu
DEV_SECRET_KEY=docker-dev-secret-key-change-in-production
DEV_MODE=true